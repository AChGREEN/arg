    <style>
        :root {
            --bg: #080c12;
            --fg: #b8c4d4;
            --muted: #3e4a5c;
            --accent: #00b894;
            --card: #0d1219;
            --border: #1a2332;
            --corruption: 0;
            --accent-r: 0;
            --accent-g: 184;
            --accent-b: 148;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg);
            color: var(--fg);
            overflow-x: hidden;
            min-height: 100vh;
        }
        ::selection { background: rgba(var(--accent-r),var(--accent-g),var(--accent-b),0.3); color: #fff; }

        /* ── Background atmosphere ── */
        .bg-blob {
            position: fixed; border-radius: 50%; pointer-events: none;
            filter: blur(100px); opacity: 0.06; z-index: 0;
        }
        .bg-blob-1 { width: 600px; height: 600px; top: -200px; left: -100px; background: var(--accent); animation: bfloat 25s ease-in-out infinite; }
        .bg-blob-2 { width: 500px; height: 500px; bottom: -150px; right: -100px; background: var(--accent); animation: bfloat 30s ease-in-out infinite reverse; }
        .bg-blob-3 { width: 300px; height: 300px; top: 50%; left: 50%; transform: translate(-50%,-50%); background: var(--accent); animation: bfloat 20s ease-in-out infinite 5s; }
        @keyframes bfloat {
            0%,100% { transform: translate(0,0) scale(1); }
            33% { transform: translate(30px,-40px) scale(1.1); }
            66% { transform: translate(-20px,30px) scale(0.9); }
        }
        .bg-grid {
            position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.03;
            background-image: linear-gradient(var(--fg) 1px, transparent 1px), linear-gradient(90deg, var(--fg) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        /* ── Scanlines ── */
        .scanlines {
            position: fixed; inset: 0; z-index: 1000; pointer-events: none; opacity: 0.3;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
            transition: opacity 0.5s;
        }

        /* ── Corruption overlay ── */
        #corruption-overlay {
            position: fixed; inset: 0; z-index: 900; pointer-events: none; opacity: 0;
            background: radial-gradient(ellipse at center, transparent 40%, rgba(255,0,0,0.15) 100%);
            transition: opacity 1s;
        }

        /* ── Initial flash ── */
        #initial-flash {
            position: fixed; inset: 0; z-index: 9999; pointer-events: none;
            background: #ff0000; opacity: 0; transition: opacity 0.15s;
        }

        /* ── Corporate content ── */
        #corporate-content { position: relative; z-index: 10; }

        /* ── Header ── */
        header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.25rem 2rem; border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px); background: rgba(8,12,18,0.8);
            position: sticky; top: 0; z-index: 50;
        }
        .logo {
            font-size: 1.3rem; font-weight: 700; letter-spacing: 0.15em;
            color: var(--accent); cursor: pointer; user-select: none;
            transition: color 0.5s;
        }
        .logo:hover { opacity: 0.8; }
        nav { display: flex; gap: 1.75rem; }
        nav a {
            color: var(--muted); text-decoration: none; font-size: 0.85rem;
            letter-spacing: 0.05em; transition: color 0.3s; cursor: pointer;
        }
        nav a:hover { color: var(--fg); }
        nav a.forbidden { cursor: not-allowed; }
        nav a.forbidden:hover { color: var(--muted); }

        /* ── Hero ── */
        .hero {
            min-height: 70vh; display: flex; flex-direction: column;
            align-items: center; justify-content: center; text-align: center;
            padding: 4rem 2rem; position: relative;
        }
        .hero h1 {
            font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700;
            letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 1rem;
        }
        .hero h1 span { color: var(--accent); transition: color 0.5s; }
        .hero p {
            font-size: 1.1rem; color: var(--muted); max-width: 500px;
            line-height: 1.6; margin-bottom: 2.5rem;
        }
        .hero-meta {
            display: flex; gap: 2rem; font-size: 0.8rem; color: var(--muted);
            letter-spacing: 0.05em; margin-top: 1rem;
        }
        .hero-meta span { opacity: 0.6; }
        .hero-btn {
            padding: 0.75rem 2rem; background: transparent;
            border: 1px solid var(--accent); color: var(--accent);
            font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em;
            cursor: pointer; transition: all 0.3s; text-transform: uppercase;
        }
        .hero-btn:hover { background: var(--accent); color: var(--bg); }

        /* ── Sections ── */
        .section {
            max-width: 900px; margin: 0 auto; padding: 4rem 2rem;
            border-top: 1px solid var(--border);
        }
        .section-label {
            font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
            color: var(--accent); margin-bottom: 1.5rem; transition: color 0.5s;
        }
        .section h2 {
            font-size: 1.8rem; font-weight: 600; margin-bottom: 1.25rem;
            letter-spacing: -0.01em;
        }
        .section p {
            color: var(--muted); line-height: 1.8; margin-bottom: 1rem;
            font-size: 0.95rem;
        }

        /* ── Invisible text (revealed on selection or high corruption) ── */
        .invisible-text {
            color: transparent; font-size: 0.95rem; line-height: 1.8;
            display: block; margin-bottom: 1rem; transition: color 2s;
        }
        .invisible-text::selection { color: #ff2244; background: rgba(255,34,68,0.15); }

        /* ── Stats row ── */
        .stats { display: flex; gap: 3rem; margin-top: 2rem; flex-wrap: wrap; }
        .stat-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.3rem; }
        .stat-value {
            font-family: 'JetBrains Mono', monospace; font-size: 1.5rem;
            font-weight: 700; color: var(--fg); transition: color 0.2s;
        }

        /* ── Project cards ── */
        .projects-grid { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
        .project-card {
            background: var(--card); border: 1px solid var(--border);
            padding: 1.5rem; transition: all 0.3s; cursor: default;
            position: relative; overflow: hidden;
        }
        .project-card::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0;
            width: 3px; background: var(--accent); transition: background 0.5s;
        }
        .project-card:hover { border-color: rgba(var(--accent-r),var(--accent-g),var(--accent-b),0.3); transform: translateX(4px); }
        .project-card .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
        .project-card h3 { font-size: 1rem; font-weight: 600; }
        .project-card .card-status {
            font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
            letter-spacing: 0.1em; padding: 0.2rem 0.6rem; border-radius: 2px;
            background: rgba(var(--accent-r),var(--accent-g),var(--accent-b),0.1);
            color: var(--accent); transition: all 0.5s;
        }
        .project-card .card-status.classified { background: rgba(255,34,68,0.1); color: #ff4466; }
        .project-card .card-status.suspended { background: rgba(255,170,0,0.1); color: #ffaa00; }
        .project-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
        .project-card.chimera { border-color: rgba(255,34,68,0.15); }
        .project-card.chimera::before { background: #ff2244; }

        /* ── Footer ── */
        footer {
            max-width: 900px; margin: 0 auto; padding: 2rem;
            border-top: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 1rem;
        }
        footer p { font-size: 0.75rem; color: var(--muted); }
        .footer-signal {
            font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
            color: var(--muted); letter-spacing: 0.05em; cursor: default;
        }

        /* ── Signal dot ── */
        #signal-dot {
            position: fixed; top: 1.5rem; right: 1.5rem; z-index: 800;
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent); opacity: 0; pointer-events: none;
            transition: opacity 0.5s, background 0.5s;
        }
        #signal-dot.visible {
            opacity: 1; pointer-events: auto; cursor: pointer;
            animation: dot-pulse 2s ease-in-out infinite;
        }
        @keyframes dot-pulse {
            0%,100% { box-shadow: 0 0 4px var(--accent); transform: scale(1); }
            50% { box-shadow: 0 0 12px var(--accent); transform: scale(1.3); }
        }

        /* ── Toast ── */
        #toast-container {
            position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
            z-index: 950; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
        }
        .toast {
            font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
            padding: 0.6rem 1.2rem; border-radius: 4px;
            background: var(--card); border: 1px solid var(--border);
            color: var(--fg); opacity: 0; transform: translateY(10px);
            transition: all 0.3s; white-space: nowrap;
        }
        .toast.show { opacity: 1; transform: translateY(0); }
        .toast-warning { border-color: rgba(255,170,0,0.4); color: #ffaa00; }
        .toast-error { border-color: rgba(255,34,68,0.4); color: #ff4466; }
        .toast-success { border-color: rgba(0,184,148,0.4); color: var(--accent); }

        /* ── Terminal ── */
        #terminal {
            position: fixed; bottom: 0; left: 0; right: 0; z-index: 850;
            height: 0; background: rgba(6,9,14,0.97);
            border-top: 1px solid var(--border);
            transition: height 0.4s cubic-bezier(0.4,0,0.2,1);
            display: flex; flex-direction: column;
            backdrop-filter: blur(20px);
        }
        #terminal.open { height: 45vh; min-height: 280px; }
        .terminal-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.5rem 1rem; border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .terminal-header span {
            font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
            letter-spacing: 0.1em; color: var(--muted);
        }
        .terminal-close {
            background: none; border: none; color: var(--muted); cursor: pointer;
            font-size: 1rem; padding: 0.2rem; transition: color 0.2s;
        }
        .terminal-close:hover { color: var(--fg); }
        #terminal-output {
            flex: 1; overflow-y: auto; padding: 0.75rem 1rem;
            font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
            line-height: 1.7;
        }
        .terminal-line { margin-bottom: 0.15rem; }
        .terminal-input { color: var(--accent); }
        .terminal-system { color: var(--muted); font-style: italic; }
        .terminal-output { color: var(--fg); }
        .terminal-warning { color: #ffaa00; }
        .terminal-error { color: #ff4466; }
        .terminal-success { color: #00ff88; }
        .terminal-prompt {
            display: flex; align-items: center; padding: 0.5rem 1rem;
            border-top: 1px solid var(--border); flex-shrink: 0;
        }
        .terminal-prompt-label {
            font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
            color: var(--accent); margin-right: 0.5rem; transition: color 0.5s;
        }
        #terminal-input {
            flex: 1; background: none; border: none; outline: none;
            font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
            color: var(--fg); caret-color: var(--accent);
        }

        /* ── Glitch effects ── */
        .glitch-flash { animation: gflash 0.15s ease-out; }
        @keyframes gflash {
            0% { filter: brightness(3) saturate(0); transform: translateX(-2px); }
            100% { filter: none; transform: none; }
        }
        .glitch-active { animation: gactive 0.5s ease-out; }
        @keyframes gactive {
            0% { filter: hue-rotate(90deg) brightness(1.5); transform: translate(-4px, 2px) skewX(-2deg); }
            15% { filter: hue-rotate(-90deg) brightness(0.5); transform: translate(4px, -1px) skewX(2deg); }
            30% { filter: hue-rotate(45deg) brightness(2); transform: translate(-2px, 1px); }
            50% { filter: hue-rotate(0) brightness(1.2); transform: translate(1px, -1px); }
            100% { filter: none; transform: none; }
        }
        .glitch-text {
            position: relative; display: inline-block;
        }
        .glitch-text::before, .glitch-text::after {
            content: attr(data-text); position: absolute; left: 0; top: 0;
            width: 100%; height: 100%; opacity: 0;
        }
        .glitch-text::before { color: #ff0040; }
        .glitch-text::after { color: #00ff88; }
        body.corruption-2 .glitch-text::before,
        body.corruption-2 .glitch-text::after {
            animation: gtext 4s ease-in-out infinite;
        }
        @keyframes gtext {
            0%,92%,100% { opacity: 0; transform: none; }
            93% { opacity: 0.8; transform: translate(-3px, 1px) skewX(-5deg); clip-path: inset(20% 0 60% 0); }
            95% { opacity: 0; }
            96% { opacity: 0.6; transform: translate(3px, -1px) skewX(5deg); clip-path: inset(60% 0 10% 0); }
            98% { opacity: 0; }
        }

        /* ── Breach content ── */
        #breach-content {
            display: none; position: fixed; inset: 0; z-index: 600;
            background: var(--bg); flex-direction: column;
        }
        .breach-header {
            padding: 1rem 1.5rem; border-bottom: 1px solid rgba(255,34,68,0.3);
            display: flex; justify-content: space-between; align-items: center;
        }
        .breach-header span {
            font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
            color: #ff4466; letter-spacing: 0.15em;
            animation: breach-pulse 1.5s ease-in-out infinite;
        }
        @keyframes breach-pulse {
            0%,100% { opacity: 1; } 50% { opacity: 0.3; }
        }
        #message-feed {
            flex: 1; overflow-y: auto; padding: 2rem;
            display: flex; flex-direction: column; gap: 1.25rem;
            max-width: 650px; margin: 0 auto; width: 100%;
        }
        .message-bubble {
            padding: 1rem 1.25rem; border-radius: 6px; max-width: 90%;
            animation: msg-in 0.3s ease-out;
        }
        @keyframes msg-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
        .message-system {
            background: rgba(255,34,68,0.08); border: 1px solid rgba(255,34,68,0.2);
            align-self: center; text-align: center;
        }
        .message-system .message-text { color: #ff4466; font-size: 0.8rem; letter-spacing: 0.1em; }
        .message-incoming {
            background: rgba(255,255,255,0.04); border: 1px solid var(--border);
            align-self: flex-start;
        }
        .message-incoming .message-sender {
            font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
            color: var(--accent); letter-spacing: 0.1em; margin-bottom: 0.4rem;
        }
        .message-incoming .message-text { color: var(--fg); font-size: 0.9rem; line-height: 1.6; }
        .message-lost {
            background: rgba(255,34,68,0.05); border: 1px solid rgba(255,34,68,0.15);
            align-self: center; text-align: center;
        }
        .message-lost .message-text {
            color: #ff4466; font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem; letter-spacing: 0.15em;
        }
        .message-final {
            align-self: center; text-align: center; padding: 0;
        }
        .message-final .message-text {
            font-size: 1.4rem; font-weight: 300; color: var(--fg);
            letter-spacing: 0.05em;
        }

        /* ── Final screen ── */
        #final-screen {
            display: none; position: fixed; inset: 0; z-index: 700;
            background: #000; flex-direction: column;
            align-items: center; justify-content: center;
        }
        #final-text {
            font-family: 'JetBrains Mono', monospace; font-size: clamp(1rem, 2.5vw, 1.5rem);
            color: rgba(184,196,212,0); letter-spacing: 0.1em;
            transition: color 3s;
        }
        #final-text.visible { color: rgba(184,196,212,0.7); }
        #final-cursor {
            display: inline-block; width: 8px; height: 1.2em;
            background: var(--accent); margin-left: 4px;
            animation: blink 1s step-end infinite; vertical-align: text-bottom;
        }
        #final-cursor.stopped { animation: none; opacity: 0; transition: opacity 2s; }
        @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

        /* ── Body classes for corruption ── */
        body.corruption-2 .invisible-text { color: rgba(255,34,68,0.15); }
        body.corruption-3 .invisible-text { color: rgba(255,34,68,0.3); }
        body.corruption-4 .invisible-text { color: rgba(255,34,68,0.5); }
        body.corruption-5 .invisible-text { color: rgba(255,34,68,0.7); }

        body.breached #corporate-content { display: none !important; }
        body.breached .scanlines { opacity: 0.6; }

        /* ── Screen shake ── */
        .shake { animation: shake 0.5s ease-in-out; }
        @keyframes shake {
            0%,100% { transform: translate(0); }
            10% { transform: translate(-5px, 3px); }
            20% { transform: translate(5px, -3px); }
            30% { transform: translate(-3px, 5px); }
            40% { transform: translate(3px, -5px); }
            50% { transform: translate(-5px, -3px); }
            60% { transform: translate(5px, 3px); }
            70% { transform: translate(-3px, -5px); }
            80% { transform: translate(3px, 5px); }
            90% { transform: translate(-5px, 3px); }
        }

        /* ── Responsive ── */
        @media (max-width: 640px) {
            header { padding: 1rem; }
            nav { gap: 1rem; }
            nav a { font-size: 0.75rem; }
            .hero { padding: 3rem 1.5rem; min-height: 60vh; }
            .hero-meta { flex-direction: column; gap: 0.5rem; }
            .section { padding: 3rem 1.5rem; }
            .stats { gap: 1.5rem; }
            footer { flex-direction: column; align-items: flex-start; }
            #terminal.open { height: 55vh; }
        }

        /* ── Reduced motion ── */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
        }
    </style>
</head>
