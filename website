    // Random word mutation
    setInterval(() => {
        if (state.corruption < 2 || state.breached) return;
        const el = mutables[Math.floor(Math.random() * mutables.length)];
        el.textContent = el.dataset.alt;
        el.style.color = 'rgba(255,34,68,0.6)';
        setTimeout(() => { el.textContent = el.dataset.original; el.style.color = ''; }, 400);
    }, 12000);

    // Signal integrity fluctuation
    setInterval(() => {
        if (state.breached) return;
        const pct = (95 + Math.random() * 4.5).toFixed(1);
        const el1 = document.getElementById('signal-integrity');
        const el2 = document.getElementById('footer-signal-pct');
        if (el1) el1.textContent = pct + '%';
        if (el2) el2.textContent = pct;
    }, 8000);

    // "Monitoring" flash at high corruption
    setInterval(() => {
        if (state.corruption < 3 || state.breached) return;
        if (Math.random() > 0.5) {
            showToast('MONITORING ACTIVE', 'error');
            if (state.corruption >= 4) triggerGlitch();
        }
    }, 20000);

    // Occasional shake at very high corruption
    setInterval(() => {
        if (state.corruption < 4 || state.breached) return;
        if (Math.random() > 0.6) triggerShake();
    }, 15000);

    /* ═══════════════════════════════════════
       INITIALIZATION
       ═══════════════════════════════════════ */
    window.addEventListener('load', () => {
        // Subtle initial red flash (50ms)
        const flash = document.getElementById('initial-flash');
        flash.style.opacity = '0.4';
        setTimeout(() => { flash.style.opacity = '0'; }, 60);

        // Console breadcrumb for ARG players
        setTimeout(() => {
            console.log('%cThis website appears normal.', 'color: #666; font-size: 12px;');
        }, 3000);
    });

    // Prevent accidental page leave during breach
    window.addEventListener('beforeunload', e => {
        if (state.corruption >= 3 && !state.breached) {
            e.preventDefault();
            e.returnValue = '';
        }
    });
    </script>
</body>
